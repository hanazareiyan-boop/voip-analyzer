# ─── کپی این فایل رو در Railway به عنوان Environment Variables وارد کن ───

# الزامی - کلید Claude API
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxx

# یک رمز دلخواه برای امنیت Webhook
WEBHOOK_SECRET=my-secret-2024

# تلگرام (اختیاری - اگر می‌خوای پیام تلگرام بگیری)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=-100123456789

# ایمیل Gmail (اختیاری - اگر می‌خوای ایمیل بگیری)
EMAIL_FROM=your-email@gmail.com
EMAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx
EMAIL_TO=manager@yourcompany.com

# ─── راهنما ───────────────────────────────────────────────────
# ANTHROPIC_API_KEY: از https://console.anthropic.com/settings/keys بگیر
#
# TELEGRAM:
#   ۱. به @BotFather در تلگرام پیام بده
#   ۲. /newbot رو بزن و نام بده
#   ۳. TOKEN رو کپی کن
#   ۴. به @userinfobot پیام بده تا CHAT_ID خودت رو بگیری
#   ۵. اگه گروه داری: ربات رو به گروه اضافه کن، CHAT_ID گروه منفی هست
#
# EMAIL (Gmail):
#   ۱. Gmail → Settings → Security → 2-Step Verification (فعال کن)
#   ۲. App Passwords → ایجاد رمز برای "Mail"
#   ۳. رمز ۱۶ کاراکتری رو در EMAIL_PASSWORD بذار
